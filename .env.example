# Copy to .env and edit:  cp .env.example .env

# --- UI ports (must be open in the security group for YOUR IP) ---
PROM_PORT=9000
GRAFANA_PORT=8443
GRAFANA_ADMIN_PASSWORD=change-me    #advance default password can be used,  applied only on FIRST init of the grafana volume

# --- Exporter host ports (local scrape only; no SG rules needed) ---
CADVISOR_PORT=8081
PGEXPORTER_PORT=9187

# --- Postgres connection for postgres_exporter ---
# APP_NETWORK: docker network your postgres container is attached to
#   find it:  docker inspect <postgres> --format '{{json .NetworkSettings.Networks}}'
APP_NETWORK=isaraadvance_default
PG_CONTAINER_NAME=isaraadvance-postgres-1
PG_DATABASE=advance
PG_SUPERUSER=postgres

# Monitor role: setup.sh CREATES this role (or syncs its password) automatically.
# Use a URL-safe password: letters+digits only. NO @ # : / characters —
# they break the connection URL parsing.
PG_MONITOR_USER=perf_monitor
PG_MONITOR_PASSWORD=change-me-alphanumeric-only #Do not use special chars

# sslmode for the exporter connection: require if your postgres enforces SSL
# (pg_hba 'hostssl' rules), disable for plain setups.
PG_SSLMODE=require
